<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView forced to a TextureView surface.

  The default SurfaceView is punched through the window as its own hardware layer, so it
  does not transform with the view hierarchy: sliding or scaling it during a navigation
  transition tears and flickers. TextureView renders inside the hierarchy and animates
  smoothly, which is what we want when the viewer opens and closes.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit" />
